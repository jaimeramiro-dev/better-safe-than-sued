# Better Safe Than Sued — environment
#
# Copy this file to .env.local and paste your Anthropic API key.
#   cp .env.example .env.local
#
# Get a key at https://console.anthropic.com/ (Settings -> API Keys).
# This key is used ONLY server-side in app/api/analyze/route.ts. It is never
# exposed to the browser. Do not prefix it with NEXT_PUBLIC_.

ANTHROPIC_API_KEY=sk-ant-your-key-here
